# ── App ───────────────────────────────────────────────
APP_NAME=HireFlow
DEBUG=false
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite:///./hireflow_dev.db
# Prod (PostgreSQL via Docker)
# DATABASE_URL=postgresql://hireflow:password@localhost:5432/hireflow

# PostgreSQL (Docker)
POSTGRES_DB=hireflow
POSTGRES_USER=hireflow
POSTGRES_PASSWORD=changethispassword

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ── Vector DB ─────────────────────────────────────────
VECTOR_BACKEND=pgvector
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=hireflow

# ── Storage ───────────────────────────────────────────
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hireflow-resumes
AWS_REGION=ap-south-1

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-this-to-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Email ─────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@hireflow.in

# ── Payments ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Adzuna ────────────────────────────────────────────
ADZUNA_APP_ID=a19a184d
ADZUNA_APP_KEY=591e04529d1dca04214ff7de2b1413b6
ADZUNA_COUNTRY=in


node_modules/
venv/
dist/